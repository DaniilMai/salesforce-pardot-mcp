# Test runner — builds the project and runs all tests
# Usage:
#   docker build -f Dockerfile.test -t sf-pardot-mcp-tests .
#   docker run --rm sf-pardot-mcp-tests
#
# Run only unit tests (no server startup):
#   docker run --rm sf-pardot-mcp-tests python -m pytest tests/test_security.py -v
#
# Run only integration tests:
#   docker run --rm sf-pardot-mcp-tests python -m pytest tests/test_integration.py -v

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# Install dependencies + pytest
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt pytest

COPY . .

# Default: run all tests
CMD ["python", "-m", "pytest", "tests/", "-v", "--tb=short"]
