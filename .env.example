# =============================================================================
# Salesforce + Pardot MCP Server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# In Railway, set these as service variables instead.

# =============================================================================
# REQUIRED — Self-Service OAuth (recommended)
# =============================================================================
# Users visit /login to connect their own Salesforce account.
# One Connected App works for ALL users across ALL organizations.
#
# Create a Connected App in your Salesforce org:
#   Setup → App Manager → New Connected App
#   - Enable OAuth Settings
#   - Callback URL: https://your-server.up.railway.app/oauth/callback
#   - Scopes: api, refresh_token, pardot_api

SF_OAUTH_CLIENT_ID=your-oauth-connected-app-consumer-key
SF_OAUTH_CLIENT_SECRET=your-oauth-connected-app-consumer-secret
SF_OAUTH_REDIRECT_URI=https://your-server.up.railway.app/oauth/callback
SF_OAUTH_LOGIN_URL=https://login.salesforce.com

# Encryption key for stored OAuth tokens (Fernet symmetric encryption).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# =============================================================================
# OPTIONAL — Legacy Single-Tenant Mode
# =============================================================================
# If set, the server also accepts these pre-configured API keys.
# Users with legacy keys use the shared SF credentials below.
# Leave empty to run in self-service-only mode.

# TEAM_API_KEYS=key1-abc-123,key2-def-456

# --- Shared Salesforce Credentials (used by legacy API keys only) ---
# SF_USERNAME=your-salesforce-username@example.com
# SF_PASSWORD=your-salesforce-password
# SF_SECURITY_TOKEN=your-security-token
# SF_DOMAIN=login
# SF_CLIENT_ID=your-connected-app-consumer-key
# SF_CLIENT_SECRET=your-connected-app-consumer-secret
# SF_INSTANCE_URL=https://yourorg.my.salesforce.com

# --- Pardot Business Unit ID (used by legacy keys; OAuth users auto-detect) ---
# PARDOT_BUSINESS_UNIT_ID=0Uv000000000001AAA

# =============================================================================
# Redis (Optional — persistent session storage)
# =============================================================================
# When set, OAuth sessions survive server restarts and redeploys.
# Without it, sessions are stored in an encrypted file (lost on container restart).
# Use Redis with TLS in production (rediss:// scheme).

# REDIS_URL=rediss://default:password@host:6379

# =============================================================================
# Server
# =============================================================================
PORT=8000
